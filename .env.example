# CONFIGURAÇÕES DO DISPOSITIVO
DEVICE_ID=192.168.1.50:5555  # IP ou Serial do ADB
SCREEN_WIDTH=1080
SCREEN_HEIGHT=2400

# Exemplo: com.instagram.android, com.zhiliaoapp.musically (TikTok), etc.
TARGET_APP_PACKAGE=com.exemplo.seuapp

# COMPORTAMENTO (HUMANIZAÇÃO)
MIN_DELAY=3.5
MAX_DELAY=9.0
SCROLL_SPEED_MIN=400
SCROLL_SPEED_MAX=1200
CHANCE_OF_MISCLICK=0.15  # 15% de chance de errar o clique propositalmente

# CAMINHOS
LOG_LEVEL=INFO
SEARCH_TERMS_FILE=data/search_terms.txt